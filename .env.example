# Copy this file to .env.local and edit values for your machine.
# .env.local is ignored by git and is loaded automatically by this package.

# Root directory where cohort-specific project folders live.
WSI_DATA_ROOT=data

# Cohort project roots.
WSI_LUSC_ROOT=${WSI_DATA_ROOT}/lusc
WSI_VULVAR_ROOT=${WSI_DATA_ROOT}/vulvar

# STAMP image cache root. Per-cohort configs append a cohort folder.
WSI_CACHE_ROOT=.cache/image_cache

# Optional path for the vulvar Excel helper notebook/script.
WSI_VULVAR_EXCEL_PATH=${WSI_VULVAR_ROOT}/Lien VSCC clinical data (selected cases from Master).xlsx
